# Copy this file to .env and adjust as needed. All values shown are the
# development defaults — app/config.py falls back to these same values
# even if .env is missing, so the app can start with zero configuration.

# dev | staging | prod — toggles debug-level logging
APP_ENV=dev

# SQLAlchemy async URL. Swapping to Postgres in production is a
# one-line change here — no code change required.
DATABASE_URL=sqlite+aiosqlite:///./data/tradeedge.db

# Used for future JWT signing (Sprint 8 auth). Change this in any
# non-dev environment.
SECRET_KEY=dev-only-change-me

# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# JSON array of allowed CORS origins. ["*"] is fine for local dev only.
CORS_ORIGINS=["*"]

# Whether CORS responses allow credentials (cookies/Authorization
# header) to be read cross-origin. Must be False if CORS_ORIGINS is
# still "*" (browsers reject the combination; FastAPI's CORSMiddleware
# would otherwise silently echo back the request's Origin instead).
# This app authenticates via a plain X-User-Id header, not cookies, so
# the default of False is correct until real auth + a real origin
# allowlist both exist.
CORS_ALLOW_CREDENTIALS=false

# Directory where ML dataset exports (JSON/CSV) are written.
EXPORT_DIR=./data/exports

# Directory where trained ML models (joblib artifacts) are written (Sprint 7).
MODELS_DIR=./data/models
